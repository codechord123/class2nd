// Firestore 보안 규칙 — Firebase 콘솔(nd-cf543) → Firestore Database → 규칙 탭에 붙여넣고 게시.
// 교사 판별: Auth 콘솔에 만든 교사 계정 이메일과 일치해야 함 (아래 이메일 확인!)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isTeacher() {
      return request.auth != null && request.auth.token.email == 'whata2mazing1@gmail.com';
    }
    function isAuthed() {
      return request.auth != null;
    }

    // 교사 설정 (평가 척도 등) — 모두 읽기, 교사만 쓰기
    match /classData/{docId} {
      allow read: if isAuthed();
      allow write: if isTeacher();
    }

    // 참고: 자리 변경 승인 기록(swap)은 classData/seatSwaps-{week} 문서에 저장
    // (교사만 쓰기 — 위 classData 규칙으로 커버됨)

    // 모둠 내 평가: evaluations/{date}/entries/{evaluatorId}
    // 대리 작성 차단: 본인 studentAuth에 바인딩된 uid로만 자기 평가 문서를 쓸 수 있다.
    // (교사는 샘플 생성·정리를 위해 예외)
    match /evaluations/{date}/entries/{evaluatorId} {
      allow read: if isAuthed();
      allow create, update: if isTeacher() || (
        isAuthed() &&
        get(/databases/$(database)/documents/studentAuth/$(evaluatorId)).data.uid == request.auth.uid
      );
      allow delete: if isTeacher();
    }

    // 모둠 간 평가: groupVotes/{date}/entries/{evaluatorId}
    match /groupVotes/{date}/entries/{evaluatorId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed();
      allow delete: if isTeacher();
    }

    // 서버 사전집계 결과 (읽기 전용, 쓰기는 Cron=Admin SDK가 규칙 우회)
    match /dailyScores/{date} {
      allow read: if isAuthed();
      allow write: if isTeacher();
    }
    match /biweeklyScores/{period} {
      allow read: if isAuthed();
      allow write: if isTeacher();
    }

    // 코인/실버 원장 (2학기) — 잔액 문서(0_balances)는 학생이 생성도 못 하게 (리셋 직후 탈취 방지)
    match /coinTxns/{txnId} {
      allow read: if isAuthed();
      allow create: if isTeacher() || (isAuthed() && txnId != "0_balances");
      allow update, delete: if isTeacher();
    }

    // 1학기 이월 지갑 차감 원장 (원본은 GitHub 정적 JSON — 불변)
    match /s1Spends/{spendId} {
      allow read: if isAuthed();
      allow create: if isTeacher() || (isAuthed() && spendId != "0_balances");
      allow update, delete: if isTeacher();
    }

    // 자리 변경 신청 (토큰 사용, 수요일 자정 마감·선착순)
    match /seatChangeRequests/{reqId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if isTeacher();
    }

    // 학생 비밀번호 해시 — 학생은 읽기 금지(해시 노출 → 4자리 무차별 대입 방지).
    //  로그인 = verify(입력 비밀번호 해시)가 저장된 hash와 일치하는 update.
    //  성공하면 그 기기 uid로 바인딩까지 한 번에 — 기기를 바꿔도 재로그인만 하면 됨.
    match /studentAuth/{studentId} {
      allow read: if isTeacher();
      allow create: if isTeacher() || (isAuthed() && request.resource.data.uid == request.auth.uid);
      allow update: if isTeacher() || (
        isAuthed() &&
        request.resource.data.verify == resource.data.hash &&
        request.resource.data.uid == request.auth.uid
      );
      allow delete: if isTeacher();
    }

    // 비밀번호 힌트 — 로그인 전에 봐야 하므로 별도 컬렉션(민감도 낮음)
    match /studentHints/{studentId} {
      allow read, create, update: if isAuthed();
      allow delete: if isTeacher();
    }

    // 비밀번호 초기화 요청 — 학생(익명)이 생성, 교사가 조회·삭제
    match /resetRequests/{studentId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed();
      allow delete: if isTeacher();
    }

    // 2학기 거북이 독서: 정식 감상문 + 임시저장(초안) + 권수 통계
    match /readingReports/{reportId} {
      allow read, create, update, delete: if isAuthed();
    }
    match /readingDrafts/{draftId} {
      allow read, create, update, delete: if isAuthed();
    }
    match /readingStats/{docId} {
      allow read, write: if isAuthed();
    }

    // 게시판/투표 (Phase 5에서 세분화 예정)
    // update 허용: 댓글·답글 달기 (학생)
    // delete도 isAuthed: 본인 글 삭제 허용 (본인 확인은 앱에서 — 익명 인증이라 규칙으로 소유자 판별 불가)
    match /suggestions/{postId} {
      allow read, create, update, delete: if isAuthed();
    }
    match /polls/{pollId} {
      allow read, create, update, delete: if isAuthed();
    }

    // 오늘의 칭찬 커버리지(누가 칭찬받았는지만 표시) — { [칭찬한사람]: 대상 }
    match /complimentCoverage/{date} {
      allow read, create, update: if isAuthed();
      allow delete: if isTeacher();
    }

    // 그 외 모든 경로는 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Firestore 보안 규칙 — Firebase 콘솔(nd-cf543) → Firestore Database → 규칙 탭에 붙여넣고 게시.
// 교사 판별: Auth 콘솔에 만든 교사 계정 이메일과 일치해야 함 (아래 이메일 확인!)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isTeacher() {
      return request.auth != null && request.auth.token.email == 'whata2mazing1@gmail.com';
    }
    function isAuthed() {
      return request.auth != null;
    }
    // 이 sid의 studentAuth에 바인딩된 기기(uid)인가 — 소유자 검증 공용 함수
    function ownsStudent(sid) {
      return get(/databases/$(database)/documents/studentAuth/$(sid)).data.uid == request.auth.uid;
    }

    // 교사 설정 (평가 척도 등) — 모두 읽기, 교사만 쓰기
    match /classData/{docId} {
      allow read: if isAuthed();
      allow write: if isTeacher();
    }
    // 예외: 거북이 응원 클릭 카운터 — 학생은 count 증가만 (한 번에 +100 이하로 어뷰징 완충)
    match /classData/turtleClicks {
      allow create: if isAuthed()
        && request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count is int
        && request.resource.data.count >= 0
        && request.resource.data.count <= 100;
      allow update: if isAuthed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count'])
        && request.resource.data.count is int
        && request.resource.data.count >= resource.data.count
        && request.resource.data.count <= resource.data.count + 100;
    }

    // 예외: 감상문 삭제 시 학생이 '재집계 요청 날짜'만 남길 수 있게 (redoDates 필드 한정)
    match /classData/autoRun {
      allow create: if isAuthed() && request.resource.data.keys().hasOnly(['redoDates']);
      allow update: if isAuthed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['redoDates']);
    }

    // 참고: 자리 변경 승인 기록(swap)은 classData/seatSwaps-{week} 문서에 저장
    // (교사만 쓰기 — 위 classData 규칙으로 커버됨)

    // 모둠 내 평가: evaluations/{date}/entries/{evaluatorId}
    // 대리 작성 차단: 본인 studentAuth에 바인딩된 uid로만 자기 평가 문서를 쓸 수 있다.
    // 읽기도 본인 것만 — 남의 원시 평가·건의 원문 열람 차단 (익명성 보호). 교사는 전체.
    match /evaluations/{date}/entries/{evaluatorId} {
      allow read: if isTeacher() || (isAuthed() && ownsStudent(evaluatorId));
      allow create, update: if isTeacher() || (isAuthed() && ownsStudent(evaluatorId));
      allow delete: if isTeacher();
    }

    // 모둠 간 평가: groupVotes/{date}/entries/{evaluatorId}
    match /groupVotes/{date}/entries/{evaluatorId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed();
      allow delete: if isTeacher();
    }

    // 점수 이의제기 — 학생은 '본인 명의 pending' 생성 + 본인 것 읽기만. 검토·조정은 교사 전용.
    match /scoreAppeals/{id} {
      allow read: if isTeacher()
        || (isAuthed() && ownsStudent(string(resource.data.studentId)));
      allow create: if isAuthed()
        && ownsStudent(string(request.resource.data.studentId))
        && request.resource.data.status == "pending"
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 500
        && request.resource.data.date is string;
      allow update, delete: if isTeacher();
    }

    // 서버 사전집계 결과 (읽기 전용, 쓰기는 Cron=Admin SDK가 규칙 우회)
    match /dailyScores/{date} {
      allow read: if isAuthed();
      allow write: if isTeacher();
    }
    match /biweeklyScores/{period} {
      allow read: if isAuthed();
      allow write: if isTeacher();
    }

    // 학생이 만들 수 있는 원장 문서 = "본인 명의의 pending 사용 신청"뿐.
    // (적립·승인·잔액 변경은 전부 교사 전용 — 자가 적립/타인 명의 신청 차단)
    // 🕓 시간창은 서버 시각(request.time, UTC)으로 KST 시(hour)를 계산해 판정 —
    // 클라이언트 차단만으론 배포 전 옛 페이지를 열어둔 기기가 뚫린다(실사례 2026-07-14).
    // 교사 설정(requestOpenHour/CloseHour)을 읽어 반영 (쓰기당 문서 1회 조회, KST는 DST 없음).
    function inRequestWindow() {
      let h = (request.time.toMillis() + 9 * 3600000) % 86400000 / 3600000;
      let p = /databases/$(database)/documents/classData/settings;
      let open = exists(p) && 'requestOpenHour' in get(p).data ? get(p).data.requestOpenHour : 16;
      let close = exists(p) && 'requestCloseHour' in get(p).data ? get(p).data.requestCloseHour : 24;
      return open == close % 24 ? true
        : close == 24 ? h >= open
        : open < close ? (h >= open && h < close)
        : (h >= open || h < close % 24);
    }
    function isValidSpendRequest() {
      return request.resource.data.status == "pending"
        && (request.resource.data.type == "spend" || request.resource.data.type == "gold")
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 100
        && ownsStudent(string(request.resource.data.studentId))
        && inRequestWindow();
    }

    // 코인/실버 원장 (2학기) — 잔액 문서(0_balances)는 학생이 생성도 못 하게 (리셋 직후 탈취 방지)
    match /coinTxns/{txnId} {
      allow read: if isAuthed();
      allow create: if isTeacher()
        || (isAuthed() && txnId != "0_balances" && isValidSpendRequest());
      allow update, delete: if isTeacher();
    }

    // 1학기 이월 지갑 차감 원장 (원본은 GitHub 정적 JSON — 불변)
    match /s1Spends/{spendId} {
      allow read: if isAuthed();
      allow create: if isTeacher()
        || (isAuthed() && spendId != "0_balances" && isValidSpendRequest());
      allow update, delete: if isTeacher();
    }

    // 자리 변경 신청 (토큰 사용, 수요일 자정 마감·선착순)
    match /seatChangeRequests/{reqId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if isTeacher();
    }

    // 학생 비밀번호 해시 — 학생은 읽기 금지(해시 노출 → 4자리 무차별 대입 방지).
    //  로그인 = verify(입력 비밀번호 해시)가 저장된 hash와 일치하는 update.
    //  성공하면 그 기기 uid로 바인딩까지 한 번에 — 기기를 바꿔도 재로그인만 하면 됨.
    match /studentAuth/{studentId} {
      allow read: if isTeacher();
      allow create: if isTeacher() || (isAuthed() && request.resource.data.uid == request.auth.uid);
      allow update: if isTeacher() || (
        isAuthed() &&
        request.resource.data.verify == resource.data.hash &&
        request.resource.data.uid == request.auth.uid
      );
      allow delete: if isTeacher();
    }

    // 비밀번호 힌트 — 로그인 전에 봐야 하므로 별도 컬렉션(민감도 낮음)
    match /studentHints/{studentId} {
      allow read, create, update: if isAuthed();
      allow delete: if isTeacher();
    }

    // 비밀번호 초기화 요청 — 학생(익명)이 생성, 교사가 조회·삭제
    match /resetRequests/{studentId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed();
      allow delete: if isTeacher();
    }

    // 2학기 거북이 독서: 정식 감상문 + 임시저장(초안) + 권수 통계
    // 감상문 문서의 소유자인가 (resource = 저장된 문서 기준)
    function ownsReport() {
      return ownsStudent(string(resource.data.studentId));
    }
    match /readingReports/{reportId} {
      // 목록(limit 쿼리)을 전원이 읽는 구조라 read는 개방 — 비공개 글 내용 숨김은 앱에서.
      allow read: if isAuthed();
      // 등록은 본인 명의 + 정식본만 (isDraft=true를 여기 넣는 우회 차단)
      allow create: if isTeacher() || (
        isAuthed()
        && ownsStudent(string(request.resource.data.studentId))
        && request.resource.data.isDraft == false
      );
      // 수정: 작성자·교사는 전체, 그 외 학생은 comments 배열만 (댓글 달기/지우기)
      allow update: if isTeacher()
        || (isAuthed() && ownsReport())
        || (isAuthed()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments']));
      allow delete: if isTeacher() || (isAuthed() && ownsReport());
    }
    // 초안은 사적인 글 — 본인만 읽고 쓴다 (목록 쿼리는 where studentId==본인 필수)
    match /readingDrafts/{draftId} {
      allow read, delete: if isTeacher()
        || (isAuthed() && ownsStudent(string(resource.data.studentId)));
      allow create, update: if isTeacher()
        || (isAuthed() && ownsStudent(string(request.resource.data.studentId)));
    }
    // 권수 통계: 학생은 total/byWeek 증감만 — s1Adj(교사 보정)는 교사 전용
    match /readingStats/{docId} {
      allow read: if isAuthed();
      allow create: if isTeacher() || (
        isAuthed() && request.resource.data.keys().hasOnly(['total', 'byWeek'])
      );
      allow update: if isTeacher() || (
        isAuthed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['total', 'byWeek'])
      );
      allow delete: if isTeacher();
    }

    // 게시판/투표 (Phase 5에서 세분화 예정)
    // update 허용: 댓글·답글 달기 (학생)
    // delete도 isAuthed: 본인 글 삭제 허용 (본인 확인은 앱에서 — 익명 인증이라 규칙으로 소유자 판별 불가)
    match /suggestions/{postId} {
      allow read, create, update, delete: if isAuthed();
    }
    match /polls/{pollId} {
      allow read, create, update, delete: if isAuthed();
    }

    // 메뉴 제안 — 학생이 "이런 메뉴 만들어주세요" 건의 (실버 차감 없음).
    // 본인 명의로만 생성, 교사가 검토 후 삭제(메뉴판 추가 or 반려).
    match /menuRequests/{reqId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && ownsStudent(string(request.resource.data.studentId));
      allow delete: if isTeacher();
    }

    // 오늘의 칭찬 커버리지(누가 칭찬받았는지만 표시) — { [칭찬한사람]: 대상 }
    match /complimentCoverage/{date} {
      allow read, create, update: if isAuthed();
      allow delete: if isTeacher();
    }

    // 그 외 모든 경로는 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
